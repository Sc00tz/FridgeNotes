# FridgeNotes configuration — copy to `.env` and fill in.
#   cp .env.example .env

# REQUIRED in production. Flask session signing key; the app refuses to start
# without it when FLASK_ENV=production. Generate a strong value with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Browser origin allowed to call the API and open WebSockets (CORS).
# Leave blank for same-origin only. Set to your deployed URL otherwise, e.g.:
#   ALLOWED_ORIGIN=https://notes.example.com
ALLOWED_ORIGIN=

# Deployment mode: "production" (default) or "development".
# Development skips the SECRET_KEY requirement and enables auto-reload.
FLASK_ENV=production

# Allow public self-registration. Disabled by default: admins create accounts
# via the admin panel. Set to true/1/yes/on to let anyone sign up.
ALLOW_REGISTRATION=false

# Add the Secure flag to the session cookie. Leave OFF for plain-HTTP LAN
# deployments (a Secure cookie is dropped by the browser over HTTP, which makes
# login silently fail to persist). Set to true ONLY when serving over HTTPS.
SESSION_COOKIE_SECURE=false
